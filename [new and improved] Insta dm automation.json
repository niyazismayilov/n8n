      "parameters": {
        "jsCode": "// Facebook Webhook Verification\n// Triggered by the Webhook node's GET request from Facebook\n\n// Get query parameters from the incoming request\nconst query = $json[\"query\"] || {};\n\nconst VERIFY_TOKEN = \"esger\"; // Replace with your own secret verify token\nconst mode = query[\"hub.mode\"];\nconst token = query[\"hub.verify_token\"];\nconst challenge = query[\"hub.challenge\"];\n\n// Validate the token and mode\nif (mode === \"subscribe\" && token === VERIFY_TOKEN) {\n  // Token is valid - respond with the challenge\n  return [\n    {\n      json: {\n        success: true,\n        message: \"Webhook verified successfully\",\n        challenge: challenge\n      }\n    }\n  ];\n} else {\n  // Token is invalid - respond with an error\n  return [\n    {\n      json: {\n        success: false,\n        message: \"Webhook verification failed\"\n      }\n    }\n  ];\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
