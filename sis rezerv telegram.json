    {
      "parameters": {
        "jsCode": "// Extract house ID and chat_id from agent output\nconst output = $input.first().json.output;\nconst houseId = output.replace('PHOTO::', '').trim();\nconst chat_id = $('Telegram Trigger3').first().json.message.chat.id;\n\n// Build list of all URLs to attempt: base image + indexed images up to 20\nconst items = [];\n\n// First image (no index)\nitems.push({ json: { url: `https://sis.house/api/image/${houseId}`, chat_id, houseId, index: 0 } });\n\n// Indexed images /1 through /20\nfor (let i = 1; i <= 20; i++) {\n  items.push({ json: { url: `https://sis.house/api/image/${houseId}/${i}`, chat_id, houseId, index: i } });\n}\n\nreturn items;"
      },
