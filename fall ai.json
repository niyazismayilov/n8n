    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\n\n// Single-scene bypass path (from 🔀 Skip Concat?)\nif (result.final_video_url) {\n  return [{ json: {\n    final_video_url: result.final_video_url,\n    title: result.title,\n    description: result.description,\n    tags: result.tags\n  }}];\n}\n\n// Normal multi-scene concat result\nconst url = result?.video?.url\n  || result?.output?.url\n  || result?.output?.video?.url\n  || result?.url\n  || result?.mp4_url\n  || result?.video_url;\n\nif (!url) throw new Error('No video URL found in concat response: ' + JSON.stringify(result));\n\nconst agentOut = $('🔄 Parse Agent Output').first().json;\n\nreturn [{\n  json: {\n    final_video_url: url,\n    title: agentOut.title,\n    description: agentOut.description,\n    tags: agentOut.tags\n  }\n}];"
      },
