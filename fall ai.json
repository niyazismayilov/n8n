        "destinationFieldName": "scenes",
        "options": {}
      },
      "id": "d88c6e32-9acc-478f-b1de-5e7a57067f0c",
      "name": "📦 Aggregate Scene URLs",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [
        3200,
        1488
      ]
    },
    {
      "parameters": {
        "jsCode": "const scenes = $input.first().json.scenes;\n\nconst mediaUrls = scenes.map((scene, i) => {\n  const url = scene?.video?.url\n    || scene?.video_url\n    || scene?.url\n    || scene?.output?.video?.url;\n  if (!url) throw new Error(`Scene ${i + 1} has no video URL. Got: ${JSON.stringify(scene)}`);\n  return url;\n});\n\n// fal-ai/ffmpeg-api requires at least 2 items — bypass concat for single scene\nif (mediaUrls.length < 2) {\n  const agentOut = $('🔄 Parse Agent Output').first().json;\n  return [{ json: {\n    skip_concat: true,\n    final_video_url: mediaUrls[0],\n    title: agentOut.title,\n    description: agentOut.description,\n    tags: agentOut.tags\n  }}];\n}\n\nreturn [{ json: { skip_concat: false, media_urls: mediaUrls } }];"
      },
      "id": "9359ad70-8fa4-4037-ad57-39f03ca69f14",
      "name": "🔧 Prepare Concat Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3440,
        1488
      ]
    },
    {
      "parameters": {
