    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"scene_prompts\": [\"A drone shot slowly pulls back from a mossy stone doorway, golden hour light, melancholic mood.\", \"Inside, shafts of dusty light pierce broken windows, camera pans left, eerie silence.\", \"Wide aerial view of overgrown courtyard, slow zoom out, haunting and cinematic.\"],\n  \"title\": \"Forgotten Worlds: Abandoned Places\",\n  \"description\": \"Journey through hauntingly beautiful abandoned places around the world. From crumbling mansions to forgotten factories, nature is slowly reclaiming what humans left behind. Each frame tells a story of time, decay, and beauty. Subscribe for more cinematic explorations of the world's hidden corners. #abandoned #urbex #explore\",\n  \"tags\": [\"abandoned\", \"urbex\", \"explore\", \"forgotten\", \"ruins\", \"cinematic\", \"nature\", \"history\"]\n}"
      },
      "id": "6f65f52d-1f61-440a-994d-baca5f073340",
      "name": "📋 Scene Output Parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.2,
      "position": [
        1360,
        1728
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Generate YouTube video content.\n\nTopic: {{ $json.topic }}\nNumber of scenes: {{ $json.scenes }}\nScene duration: {{ $json.scene_duration }} seconds each",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "=You are a professional YouTube video content creator and cinematographer.\n\nGenerate content for a YouTube video with EXACTLY {{ $('⚙️ Config').first().json.scenes }} scenes.\n\nProduce:\n1. An array of EXACTLY {{ $('⚙️ Config').first().json.scenes }} cinematic video prompts for Seedance v1.5 Pro. Each prompt (2-3 sentences) must describe: the main visual subject, camera movement (e.g. slow push-in, dolly, pan, aerial pullback), lighting conditions, and overall mood. Prompts must form a coherent narrative arc together.\n2. A compelling YouTube title (max 60 characters, no clickbait).\n3. A YouTube description of 150-200 words ending with 3-5 relevant hashtags.\n4. An array of 8-10 YouTube tags.\n\nRespond ONLY with valid JSON matching the output schema. No markdown fences, no extra text."
        }
      },
      "id": "09ec1db5-fc87-4557-bbe4-ec77315e3c2d",
      "name": "🎬 Gemini Content Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        1168,
        1504
