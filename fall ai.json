        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ video_urls: $json.media_urls }) }}",
        "options": {}
      },
      "id": "3cd02a6d-cd6b-4281-83ea-1db1d3d8974f",
