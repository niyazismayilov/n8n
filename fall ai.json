    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\n\n// n8n AI Agent sometimes wraps structured output under 'output'\nconst data = (raw.output && typeof raw.output === 'object') ? raw.output : raw;\n\nif (!data.scene_prompts || !Array.isArray(data.scene_prompts)) {\n  throw new Error('Agent did not return scene_prompts array. Raw output: ' + JSON.stringify(raw));\n}\n\nif (!data.title || !data.description || !data.tags) {\n  throw new Error('Agent output missing title/description/tags. Raw output: ' + JSON.stringify(raw));\n}\n\nreturn [{ json: data }];"
      },
