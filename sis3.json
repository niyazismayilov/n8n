    {
      "parameters": {
        "jsCode": "// Loop through all incoming items\nfor (const item of $input.all()) {\n  const originalText = item.json.message.text;\n\n  // Check if text exists and starts with 'Y'\n  if (originalText && originalText.startsWith('Y')) {\n    // Remove the first character (index 0)\n    item.json.cleanDate = originalText.substring(1);\n  } else {\n    // Fallback if it doesn't start with Y\n    item.json.cleanDate = originalText;\n  }\n}\n\nreturn $input.all();"
