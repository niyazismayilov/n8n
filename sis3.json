    {
      "parameters": {
        "jsCode": "const raw = $json.text || $json.data || '';\n\n// 🛑 Empty response\nif (!raw.trim()) {\n  return [{\n    text: '🌞 Bugünün rezervasiyaları:\\n\\n❌ Heç bir rezervasiya tapılmadı.'\n  }];\n}\n\n// 🔹 Split each reservation by new line\nconst lines = raw.split('\\n').filter(l => l.trim());\n\nlet text = '🌞 Bugünün rezervasiyaları:\\n';\n\nlines.forEach((line) => {\n  // Format: Rezervasiya #ID | name | phone | email | dates | room | [Qeyd: ...] [| Əlavə: ...]\n  const parts = line.split('|').map(p => p.trim());\n\n  const reservationId = parts[0] || '-';\n  const name = parts[1] || '-';\n  const phone = parts[2] || '-';\n  const email = parts[3] || '-';\n  const dates = parts[4] || '-';\n  const room = parts[5] || '-';\n\n  // Parts 6+ can be: \"Qeyd: ...\" or \"Əlavə: ...\"\n  let qeyd = '';\n  let elave = '';\n  for (let i = 6; i < parts.length; i++) {\n    if (parts[i].startsWith('Qeyd:')) {\n      qeyd = parts[i].substring(5).trim();\n    } else if (parts[i].startsWith('Əlavə:') || parts[i].toLowerCase().startsWith('elave:')) {\n      elave = parts[i].replace(/^Əlavə:|^Elave:/i, '').trim();\n    }\n  }\n\n  text += `\n━━━━━━━━━━━━━━━━\n🧾 ${reservationId}\n👤 ${name}\n📞 ${phone}\n📧 ${email}\n📅 ${dates}\n🏠 ${room}\n`;\n  if (qeyd) text += `📝 Qeyd: ${qeyd}\\n`;\n  if (elave) text += `✨ Əlavə: ${elave}\\n`;\n});\n\nreturn [{ text }];"
      },
