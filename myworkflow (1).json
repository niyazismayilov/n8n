    {
      "parameters": {
        "jsCode": "const items = $input.first().json;\n\nif (!items.title || items.title.length === 0) {\n  return [];\n}\n\nconst results = items.title.map((title, i) => {\n  const yearKm = items.year_km?.[i] || '';\n  const parts = yearKm.split(',').map(s => s.trim());\n  \n  return {\n    title: title?.trim() || '',\n    price: items.price?.[i]?.trim() || '',\n    year: parts[0] || '',\n    engine: parts[1] || '',\n    mileage: parts[2] || '',\n    location: items.location?.[i]?.trim() || '',\n    url: 'https://turbo.az' + (items.listing_url?.[i] || ''),\n    scraped_at: new Date().toISOString()\n  };\n});\n\nreturn results.map(item => ({ json: item }));"
      },
