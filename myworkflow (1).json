      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst seen = new Set();\nconst indices = [];\n\ndata.link.forEach((l, i) => {\n  if (!seen.has(l)) {\n    seen.add(l);\n    indices.push(i);\n  }\n});\n\nreturn [{\n  json: {\n    title: indices.map(i => data.title[i]),\n    qiymet: indices.map(i => data.qiymet[i]),\n    unvan: indices.map(i => data.unvan[i]),\n    link: indices.map(i => \"https://bina.az\" + data.link[i])\n  }\n}];"
      },
